{
  "id": "report-ready",
  "slug": "report-ready",
  "name": "Report Ready",
  "version": "1.0.0",
  "category": "notifications",
  "useCase": "Notify customers when a generated report, export, or analysis is ready.",
  "description": "A premium completion email for exports, analytics, and generated documents.",
  "subject": "{{report_name}} is ready",
  "tags": [
    "transactional",
    "notifications",
    "report",
    "export"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Elena"
    },
    {
      "name": "report_name",
      "type": "string",
      "description": "Report name.",
      "required": true,
      "example": "Revenue Snapshot"
    },
    {
      "name": "workspace_name",
      "type": "string",
      "description": "Workspace name.",
      "required": true,
      "example": "Northstar Studio"
    },
    {
      "name": "data_cutoff",
      "type": "string",
      "description": "Data cutoff date.",
      "required": true,
      "example": "June 25, 2026"
    },
    {
      "name": "file_type",
      "type": "string",
      "description": "Report file type.",
      "required": true,
      "example": "PDF"
    },
    {
      "name": "report_url",
      "type": "string",
      "description": "Absolute URL to generated report.",
      "required": true,
      "example": "https://app.example.com/reports/revenue-snapshot"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Elena",
    "report_name": "Revenue Snapshot",
    "workspace_name": "Northstar Studio",
    "data_cutoff": "June 25, 2026",
    "file_type": "PDF",
    "report_url": "https://app.example.com/reports/revenue-snapshot"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\n{{report_name}} finished processing for {{workspace_name}}. The report includes data through {{data_cutoff}}.\n\nReport: {{report_name}}\nWorkspace: {{workspace_name}}\nData through: {{data_cutoff}}\nFile type: {{file_type}}\n\nOpen report: {{report_url}}\n\nAccess follows your workspace permissions, so only approved members can open this report.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Report Ready</mj-title>\n    <mj-preview>A premium completion email for exports, analytics, and generated documents.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#101114\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f3f4f0\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#050505\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#b8ff2c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Report ready</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Your report is ready to review</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, {{report_name}} finished processing for {{workspace_name}}. The report includes data through {{data_cutoff}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Report</mj-text>\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{report_name}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Workspace</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{workspace_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Data through</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{data_cutoff}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">File type</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{file_type}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{report_url}}\" background-color=\"#b8ff2c\" color=\"#101114\" padding=\"26px 0 8px\">Open report</mj-button>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">Access follows your workspace permissions, so only approved members can open this report.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
