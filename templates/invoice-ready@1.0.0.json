{
  "schemaVersion": "1.0",
  "id": "invoice-ready",
  "slug": "invoice-ready",
  "name": "Invoice Ready",
  "version": "1.0.0",
  "category": "billing",
  "subject": "Invoice {{invoice_number}} is ready",
  "useCase": "Send customers a premium invoice notice with direct access to billing details.",
  "description": "A sharp invoice email designed for SaaS, services, and subscription billing.",
  "tags": [
    "transactional",
    "billing",
    "invoice",
    "receipt"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Alex"
    },
    {
      "name": "invoice_number",
      "type": "string",
      "description": "Invoice number.",
      "required": true,
      "example": "INV-2048"
    },
    {
      "name": "amount_due",
      "type": "string",
      "description": "Invoice total.",
      "required": true,
      "example": "$248.00",
      "format": "currency"
    },
    {
      "name": "due_date",
      "type": "string",
      "description": "Invoice due date.",
      "required": true,
      "example": "July 8, 2026",
      "format": "date"
    },
    {
      "name": "billing_period",
      "type": "string",
      "description": "Billing period.",
      "required": true,
      "example": "June 1 - June 30"
    },
    {
      "name": "invoice_url",
      "type": "string",
      "description": "Absolute URL to the invoice.",
      "required": true,
      "example": "https://app.example.com/billing/invoices/2048",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Alex",
    "invoice_number": "INV-2048",
    "amount_due": "$248.00",
    "due_date": "July 8, 2026",
    "billing_period": "June 1 - June 30",
    "invoice_url": "https://app.example.com/billing/invoices/2048"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Invoice Ready</mj-title>\n    <mj-preview>A sharp invoice email designed for SaaS, services, and subscription billing.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#101114\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f3f4f0\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#050505\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#b8ff2c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Invoice issued</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Your invoice is ready for review</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, invoice {{invoice_number}} for {{product_name}} is now available. You can download the receipt or review the billing breakdown.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Amount due</mj-text>\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{amount_due}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Invoice</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{invoice_number}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Due date</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{due_date}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Billing period</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{billing_period}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{invoice_url}}\" background-color=\"#b8ff2c\" color=\"#101114\" padding=\"26px 0 8px\">View invoice</mj-button>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If your account is on autopay, no action is needed unless your payment method has changed.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\ninvoice {{invoice_number}} for {{product_name}} is now available. You can download the receipt or review the billing breakdown.\n\nAmount due: {{amount_due}}\nInvoice: {{invoice_number}}\nDue date: {{due_date}}\nBilling period: {{billing_period}}\n\nView invoice: {{invoice_url}}\n\nIf your account is on autopay, no action is needed unless your payment method has changed.",
  "preview": "previews/invoice-ready@1.0.0.png",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
