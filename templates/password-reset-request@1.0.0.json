{
  "schemaVersion": "1.0",
  "id": "password-reset-request",
  "slug": "password-reset-request",
  "name": "Password Reset Request",
  "version": "1.0.0",
  "category": "authentication",
  "subject": "Reset your {{product_name}} password",
  "useCase": "Help users reset a password with clear account safety messaging.",
  "description": "A premium password reset email with a direct action and security context.",
  "tags": [
    "transactional",
    "authentication",
    "password-reset",
    "security"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Daniel"
    },
    {
      "name": "expires_in",
      "type": "string",
      "description": "Reset link expiry window.",
      "required": true,
      "example": "30 minutes"
    },
    {
      "name": "account_email",
      "type": "string",
      "description": "Account email address.",
      "required": true,
      "example": "daniel@example.com",
      "format": "email"
    },
    {
      "name": "location",
      "type": "string",
      "description": "Approximate request location.",
      "required": true,
      "example": "Austin, TX"
    },
    {
      "name": "requested_at",
      "type": "string",
      "description": "Human-readable request time.",
      "required": true,
      "example": "9:18 AM",
      "format": "date-time"
    },
    {
      "name": "reset_url",
      "type": "string",
      "description": "Absolute URL to reset password.",
      "required": true,
      "example": "https://app.example.com/auth/reset",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Daniel",
    "expires_in": "30 minutes",
    "account_email": "daniel@example.com",
    "location": "Austin, TX",
    "requested_at": "9:18 AM",
    "reset_url": "https://app.example.com/auth/reset"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Password Reset Request</mj-title>\n    <mj-preview>A premium password reset email with a direct action and security context.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#1f1215\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#fff1f2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#2a0d12\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#f43f5e\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Password reset</mj-text>\n        <mj-text color=\"#fff7f8\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Create a new password</mj-text>\n        <mj-text color=\"#fff7f8\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, use the button below to reset your {{product_name}} password. The reset link expires in {{expires_in}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#ffe4e6\" color=\"#1f1215\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Reset window</mj-text>\n        <mj-text background-color=\"#ffe4e6\" color=\"#1f1215\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{expires_in}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Account</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{account_email}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Requested from</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{location}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Request time</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{requested_at}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{reset_url}}\" background-color=\"#f43f5e\" color=\"#ffffff\" padding=\"26px 0 8px\">Reset password</mj-button>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If you did not ask to reset your password, keep your current password and review recent account activity.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\nuse the button below to reset your {{product_name}} password. The reset link expires in {{expires_in}}.\n\nReset window: {{expires_in}}\nAccount: {{account_email}}\nRequested from: {{location}}\nRequest time: {{requested_at}}\n\nReset password: {{reset_url}}\n\nIf you did not ask to reset your password, keep your current password and review recent account activity.",
  "preview": "previews/password-reset-request@1.0.0.png",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
