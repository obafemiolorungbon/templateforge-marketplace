{
  "id": "email-verification",
  "slug": "email-verification",
  "name": "Email Verification",
  "version": "1.0.0",
  "category": "authentication",
  "useCase": "Verify a new user email address with a polished account activation flow.",
  "description": "A simple but elevated verification email for account creation and email changes.",
  "subject": "Verify {{account_email}} for {{product_name}}",
  "tags": [
    "transactional",
    "authentication",
    "email-verification",
    "account"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Sofia"
    },
    {
      "name": "account_email",
      "type": "string",
      "description": "Email address to verify.",
      "required": true,
      "example": "sofia@example.com"
    },
    {
      "name": "expires_in",
      "type": "string",
      "description": "Verification link expiry window.",
      "required": true,
      "example": "24 hours"
    },
    {
      "name": "requested_at",
      "type": "string",
      "description": "Human-readable request time.",
      "required": true,
      "example": "June 26, 2026 at 8:30 AM"
    },
    {
      "name": "verify_url",
      "type": "url",
      "description": "Absolute URL to verify email.",
      "required": true,
      "example": "https://app.example.com/auth/verify-email"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Sofia",
    "account_email": "sofia@example.com",
    "expires_in": "24 hours",
    "requested_at": "June 26, 2026 at 8:30 AM",
    "verify_url": "https://app.example.com/auth/verify-email"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\nverify {{account_email}} to finish setting up your {{product_name}} account and keep account recovery secure.\n\nAccount email: {{account_email}}\nProduct: {{product_name}}\nExpires in: {{expires_in}}\nRequested at: {{requested_at}}\n\nVerify email: {{verify_url}}\n\nIf you did not create this account, you can ignore this message.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Email Verification</mj-title>\n    <mj-preview>A simple but elevated verification email for account creation and email changes.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#12161f\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f7fbf2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#111827\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#34d399\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Verify email</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Confirm your email address</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\" opacity=\"0.84\">Hi {{first_name}}, verify {{account_email}} to finish setting up your {{product_name}} account and keep account recovery secure.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" border-radius=\"18px\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Account email</mj-text>\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" border-radius=\"18px\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{account_email}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Product</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{product_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Expires in</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{expires_in}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Requested at</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{requested_at}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{verify_url}}\" background-color=\"#34d399\" color=\"#07130d\" padding=\"26px 0 8px\">Verify email</mj-button>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If you did not create this account, you can ignore this message.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
