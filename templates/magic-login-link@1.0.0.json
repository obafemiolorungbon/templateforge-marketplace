{
  "schemaVersion": "1.0",
  "id": "magic-login-link",
  "slug": "magic-login-link",
  "name": "Magic Login Link",
  "version": "1.0.0",
  "category": "authentication",
  "subject": "Your secure sign-in link for {{product_name}}",
  "useCase": "Send a passwordless login link with strong security context.",
  "description": "A sleek magic-link email with expiry and request metadata.",
  "tags": [
    "transactional",
    "authentication",
    "magic-link",
    "security"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Lena"
    },
    {
      "name": "expires_in",
      "type": "string",
      "description": "Magic link expiry window.",
      "required": true,
      "example": "15 minutes"
    },
    {
      "name": "location",
      "type": "string",
      "description": "Approximate request location.",
      "required": true,
      "example": "Lagos, Nigeria"
    },
    {
      "name": "device_name",
      "type": "string",
      "description": "Requesting device or browser.",
      "required": true,
      "example": "Chrome on Windows"
    },
    {
      "name": "requested_at",
      "type": "string",
      "description": "Human-readable request time.",
      "required": true,
      "example": "10:42 AM",
      "format": "date-time"
    },
    {
      "name": "login_url",
      "type": "string",
      "description": "Absolute URL for passwordless login.",
      "required": true,
      "example": "https://app.example.com/auth/magic",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Lena",
    "expires_in": "15 minutes",
    "location": "Lagos, Nigeria",
    "device_name": "Chrome on Windows",
    "requested_at": "10:42 AM",
    "login_url": "https://app.example.com/auth/magic"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Magic Login Link</mj-title>\n    <mj-preview>A sleek magic-link email with expiry and request metadata.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#101114\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f3f4f0\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#050505\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#b8ff2c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Secure sign-in</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Use this link to continue securely</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, we received a request to sign in to {{product_name}}. This link is single-use and expires in {{expires_in}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Expires in</mj-text>\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{expires_in}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Requested from</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{location}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Device</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{device_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Request time</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{requested_at}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{login_url}}\" background-color=\"#b8ff2c\" color=\"#101114\" padding=\"26px 0 8px\">Sign in securely</mj-button>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If you did not request this link, you can ignore this email.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\nwe received a request to sign in to {{product_name}}. This link is single-use and expires in {{expires_in}}.\n\nExpires in: {{expires_in}}\nRequested from: {{location}}\nDevice: {{device_name}}\nRequest time: {{requested_at}}\n\nSign in securely: {{login_url}}\n\nIf you did not request this link, you can ignore this email.",
  "preview": "previews/magic-login-link@1.0.0.png",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
