{
  "id": "new-device-login",
  "slug": "new-device-login",
  "name": "New Device Login",
  "version": "1.0.0",
  "category": "authentication",
  "useCase": "Alert users when their account is accessed from a new device.",
  "description": "A security notification with crisp metadata and a fast account-review action.",
  "subject": "New sign-in to {{product_name}} from {{device_name}}",
  "tags": [
    "transactional",
    "authentication",
    "security",
    "new-device"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Riley"
    },
    {
      "name": "device_name",
      "type": "string",
      "description": "New device or browser.",
      "required": true,
      "example": "Edge on Windows"
    },
    {
      "name": "location",
      "type": "string",
      "description": "Approximate login location.",
      "required": true,
      "example": "Berlin, Germany"
    },
    {
      "name": "login_time",
      "type": "string",
      "description": "Human-readable login time.",
      "required": true,
      "example": "June 26, 2026 at 11:03 AM"
    },
    {
      "name": "ip_address",
      "type": "string",
      "description": "IP address used for login.",
      "required": true,
      "example": "203.0.113.42"
    },
    {
      "name": "activity_url",
      "type": "string",
      "description": "Absolute URL to account activity.",
      "required": true,
      "example": "https://app.example.com/security/activity"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Riley",
    "device_name": "Edge on Windows",
    "location": "Berlin, Germany",
    "login_time": "June 26, 2026 at 11:03 AM",
    "ip_address": "203.0.113.42",
    "activity_url": "https://app.example.com/security/activity"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\nyour {{product_name}} account was accessed from {{device_name}}. Review the details below if this was not you.\n\nDevice: {{device_name}}\nLocation: {{location}}\nTime: {{login_time}}\nIP address: {{ip_address}}\n\nReview account activity: {{activity_url}}\n\nIf this was you, no action is needed. If not, change your password and revoke unknown sessions.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>New Device Login</mj-title>\n    <mj-preview>A security notification with crisp metadata and a fast account-review action.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#1c1917\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#fff7ed\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#22120b\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#fb923c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Security notice</mj-text>\n        <mj-text color=\"#fff7ed\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">We noticed a new sign-in</mj-text>\n        <mj-text color=\"#fff7ed\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, your {{product_name}} account was accessed from {{device_name}}. Review the details below if this was not you.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#ffedd5\" color=\"#1c1917\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Device</mj-text>\n        <mj-text background-color=\"#ffedd5\" color=\"#1c1917\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{device_name}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">Location</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{location}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">Time</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{login_time}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">IP address</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{ip_address}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{activity_url}}\" background-color=\"#fb923c\" color=\"#1c1007\" padding=\"26px 0 8px\">Review account activity</mj-button>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If this was you, no action is needed. If not, change your password and revoke unknown sessions.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
