{
  "id": "workspace-invite",
  "slug": "workspace-invite",
  "name": "Workspace Invite",
  "version": "1.0.0",
  "category": "onboarding",
  "useCase": "Invite a teammate into a workspace with a polished, high-trust acceptance flow.",
  "description": "A premium team invitation email with a bold workspace handoff and clear expiry details.",
  "subject": "{{inviter_name}} invited you to {{workspace_name}}",
  "tags": [
    "transactional",
    "onboarding",
    "workspace",
    "invite"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Maya"
    },
    {
      "name": "inviter_name",
      "type": "string",
      "description": "Name of the person sending the invite.",
      "required": true,
      "example": "Jordan Lee"
    },
    {
      "name": "workspace_name",
      "type": "string",
      "description": "Workspace or team name.",
      "required": true,
      "example": "Northstar Studio"
    },
    {
      "name": "role_name",
      "type": "string",
      "description": "Role assigned to the recipient.",
      "required": true,
      "example": "Editor"
    },
    {
      "name": "expires_at",
      "type": "string",
      "description": "Human-readable invitation expiry.",
      "required": true,
      "example": "Friday at 5:00 PM"
    },
    {
      "name": "invite_url",
      "type": "url",
      "description": "Absolute URL for accepting the invite.",
      "required": true,
      "example": "https://app.example.com/invite/northstar"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Maya",
    "inviter_name": "Jordan Lee",
    "workspace_name": "Northstar Studio",
    "role_name": "Editor",
    "expires_at": "Friday at 5:00 PM",
    "invite_url": "https://app.example.com/invite/northstar"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\n{{inviter_name}} invited you to join {{workspace_name}}. Accept the invite to review projects, comments, and shared assets in one place.\n\nInvite expires: {{expires_at}}\nInvited by: {{inviter_name}}\nWorkspace: {{workspace_name}}\nRole: {{role_name}}\n\nAccept invite: {{invite_url}}\n\nThis invitation was sent because {{inviter_name}} added your email to {{workspace_name}}.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Workspace Invite</mj-title>\n    <mj-preview>A premium team invitation email with a bold workspace handoff and clear expiry details.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#101114\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f3f4f0\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#050505\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#b8ff2c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Workspace access</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">You have a seat waiting in {{workspace_name}}</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\" opacity=\"0.84\">Hi {{first_name}}, {{inviter_name}} invited you to join {{workspace_name}}. Accept the invite to review projects, comments, and shared assets in one place.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" border-radius=\"18px\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Invite expires</mj-text>\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" border-radius=\"18px\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{expires_at}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Invited by</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{inviter_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Workspace</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{workspace_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Role</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{role_name}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{invite_url}}\" background-color=\"#b8ff2c\" color=\"#101114\" padding=\"26px 0 8px\">Accept invite</mj-button>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">This invitation was sent because {{inviter_name}} added your email to {{workspace_name}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
