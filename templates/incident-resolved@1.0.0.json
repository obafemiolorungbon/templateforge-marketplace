{
  "schemaVersion": "1.0",
  "id": "incident-resolved",
  "slug": "incident-resolved",
  "name": "Incident Resolved",
  "version": "1.0.0",
  "category": "notifications",
  "subject": "{{incident_name}} has been resolved",
  "useCase": "Send customers a concise incident resolution notice with status and postmortem access.",
  "description": "A status-update email that feels calm, credible, and operationally mature.",
  "tags": [
    "transactional",
    "notifications",
    "status",
    "incident"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Ada"
    },
    {
      "name": "incident_name",
      "type": "string",
      "description": "Incident name.",
      "required": true,
      "example": "API latency incident"
    },
    {
      "name": "resolved_at",
      "type": "string",
      "description": "Human-readable resolution time.",
      "required": true,
      "example": "June 26 at 1:42 PM",
      "format": "date-time"
    },
    {
      "name": "status_label",
      "type": "string",
      "description": "Current incident status.",
      "required": true,
      "example": "Resolved"
    },
    {
      "name": "impact_window",
      "type": "string",
      "description": "Incident impact window.",
      "required": true,
      "example": "38 minutes"
    },
    {
      "name": "service_name",
      "type": "string",
      "description": "Affected service name.",
      "required": true,
      "example": "Transactional API"
    },
    {
      "name": "status_url",
      "type": "string",
      "description": "Absolute URL to incident details.",
      "required": true,
      "example": "https://status.example.com/incidents/api-latency",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Ada",
    "incident_name": "API latency incident",
    "resolved_at": "June 26 at 1:42 PM",
    "status_label": "Resolved",
    "impact_window": "38 minutes",
    "service_name": "Transactional API",
    "status_url": "https://status.example.com/incidents/api-latency"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Incident Resolved</mj-title>\n    <mj-preview>A status-update email that feels calm, credible, and operationally mature.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#12161f\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f7fbf2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#111827\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#34d399\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Resolved</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">{{incident_name}} is resolved</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, we resolved {{incident_name}} at {{resolved_at}}. A summary is available now, and the full review will be posted when complete.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Status</mj-text>\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{status_label}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Resolved at</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{resolved_at}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Impact window</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{impact_window}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Affected service</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{service_name}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{status_url}}\" background-color=\"#34d399\" color=\"#07130d\" padding=\"26px 0 8px\">View incident summary</mj-button>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">We will update the incident page if additional findings become available.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\nwe resolved {{incident_name}} at {{resolved_at}}. A summary is available now, and the full review will be posted when complete.\n\nStatus: {{status_label}}\nResolved at: {{resolved_at}}\nImpact window: {{impact_window}}\nAffected service: {{service_name}}\n\nView incident summary: {{status_url}}\n\nWe will update the incident page if additional findings become available.",
  "preview": "previews/incident-resolved@1.0.0.png",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
