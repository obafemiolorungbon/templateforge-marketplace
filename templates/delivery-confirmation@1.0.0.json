{
  "schemaVersion": "1.0",
  "id": "delivery-confirmation",
  "slug": "delivery-confirmation",
  "name": "Delivery Confirmation",
  "version": "1.0.0",
  "category": "commerce",
  "subject": "Order {{order_number}} was delivered",
  "useCase": "Confirm delivery and direct customers to support or order details if needed.",
  "description": "A polished delivery confirmation that closes the loop without sounding generic.",
  "tags": [
    "transactional",
    "commerce",
    "delivery",
    "tracking"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Grace"
    },
    {
      "name": "order_number",
      "type": "string",
      "description": "Order number.",
      "required": true,
      "example": "TF-10429"
    },
    {
      "name": "delivery_location",
      "type": "string",
      "description": "Delivery location note.",
      "required": true,
      "example": "front desk"
    },
    {
      "name": "delivered_at",
      "type": "string",
      "description": "Human-readable delivery time.",
      "required": true,
      "example": "June 26 at 2:14 PM",
      "format": "date-time"
    },
    {
      "name": "carrier_name",
      "type": "string",
      "description": "Shipping carrier name.",
      "required": true,
      "example": "UPS"
    },
    {
      "name": "order_url",
      "type": "string",
      "description": "Absolute URL to order details.",
      "required": true,
      "example": "https://shop.example.com/orders/TF-10429",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Grace",
    "order_number": "TF-10429",
    "delivery_location": "front desk",
    "delivered_at": "June 26 at 2:14 PM",
    "carrier_name": "UPS",
    "order_url": "https://shop.example.com/orders/TF-10429"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Delivery Confirmation</mj-title>\n    <mj-preview>A polished delivery confirmation that closes the loop without sounding generic.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#12161f\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f7fbf2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#111827\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#34d399\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Delivered</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Your order has arrived</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, order {{order_number}} was marked delivered to {{delivery_location}} on {{delivered_at}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Delivered</mj-text>\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{delivered_at}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Location</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{delivery_location}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Carrier</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{carrier_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Order</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{order_number}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{order_url}}\" background-color=\"#34d399\" color=\"#07130d\" padding=\"26px 0 8px\">View delivery details</mj-button>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If the package is not where expected, check nearby delivery areas or contact support from the order page.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\norder {{order_number}} was marked delivered to {{delivery_location}} on {{delivered_at}}.\n\nDelivered: {{delivered_at}}\nLocation: {{delivery_location}}\nCarrier: {{carrier_name}}\nOrder: {{order_number}}\n\nView delivery details: {{order_url}}\n\nIf the package is not where expected, check nearby delivery areas or contact support from the order page.",
  "preview": "previews/delivery-confirmation@1.0.0.png",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
