{
  "id": "onboarding-checklist",
  "slug": "onboarding-checklist",
  "name": "Onboarding Checklist",
  "version": "1.0.0",
  "category": "onboarding",
  "useCase": "Bring users back to finish setup after they complete part of onboarding.",
  "description": "A focused progress email that makes the remaining setup path feel manageable.",
  "subject": "{{completed_steps}} of {{total_steps}} setup steps complete",
  "tags": [
    "transactional",
    "onboarding",
    "checklist",
    "activation"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Ife"
    },
    {
      "name": "completed_steps",
      "type": "string",
      "description": "Number of completed setup steps.",
      "required": true,
      "example": "3"
    },
    {
      "name": "total_steps",
      "type": "string",
      "description": "Total number of setup steps.",
      "required": true,
      "example": "5"
    },
    {
      "name": "next_step",
      "type": "string",
      "description": "Next recommended setup action.",
      "required": true,
      "example": "Connect your sending domain"
    },
    {
      "name": "time_estimate",
      "type": "string",
      "description": "Estimated time to complete the next step.",
      "required": true,
      "example": "4 minutes"
    },
    {
      "name": "workspace_name",
      "type": "string",
      "description": "Workspace name.",
      "required": true,
      "example": "Rivet Labs"
    },
    {
      "name": "checklist_url",
      "type": "url",
      "description": "Absolute URL to the setup checklist.",
      "required": true,
      "example": "https://app.example.com/setup"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Ife",
    "completed_steps": "3",
    "total_steps": "5",
    "next_step": "Connect your sending domain",
    "time_estimate": "4 minutes",
    "workspace_name": "Rivet Labs",
    "checklist_url": "https://app.example.com/setup"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\nyou have finished {{completed_steps}} of {{total_steps}} setup steps. Complete the next step to unlock a cleaner production workflow.\n\nProgress: {{completed_steps}} / {{total_steps}}\nNext step: {{next_step}}\nEstimated time: {{time_estimate}}\nWorkspace: {{workspace_name}}\n\nContinue setup: {{checklist_url}}\n\nWe saved your progress, so you can pick up exactly where you left off.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Onboarding Checklist</mj-title>\n    <mj-preview>A focused progress email that makes the remaining setup path feel manageable.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#12161f\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f7fbf2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#111827\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#34d399\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Setup progress</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Your workspace is close to launch-ready</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\" opacity=\"0.84\">Hi {{first_name}}, you have finished {{completed_steps}} of {{total_steps}} setup steps. Complete the next step to unlock a cleaner production workflow.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" border-radius=\"18px\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Progress</mj-text>\n        <mj-text background-color=\"#dcfce7\" color=\"#12161f\" border-radius=\"18px\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{completed_steps}} / {{total_steps}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Next step</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{next_step}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Estimated time</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{time_estimate}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#596272;font-size:13px;\">Workspace</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #d6eadc;color:#12161f;font-size:13px;font-weight:700;\">{{workspace_name}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{checklist_url}}\" background-color=\"#34d399\" color=\"#07130d\" padding=\"26px 0 8px\">Continue setup</mj-button>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">We saved your progress, so you can pick up exactly where you left off.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#596272\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
