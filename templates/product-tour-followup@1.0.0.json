{
  "schemaVersion": "1.0",
  "id": "product-tour-followup",
  "slug": "product-tour-followup",
  "name": "Product Tour Follow-up",
  "version": "1.0.0",
  "category": "onboarding",
  "subject": "Next up in {{product_name}}: {{next_feature}}",
  "useCase": "Follow up after a product tour with one contextual next action.",
  "description": "A crisp lifecycle email that turns a guided tour into product adoption.",
  "tags": [
    "transactional",
    "onboarding",
    "product-tour",
    "activation"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product name.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Kai"
    },
    {
      "name": "next_feature",
      "type": "string",
      "description": "Recommended feature name.",
      "required": true,
      "example": "Brand approvals"
    },
    {
      "name": "workspace_name",
      "type": "string",
      "description": "Workspace name.",
      "required": true,
      "example": "Signal Market"
    },
    {
      "name": "use_case_name",
      "type": "string",
      "description": "Use case name.",
      "required": true,
      "example": "Launch review"
    },
    {
      "name": "time_estimate",
      "type": "string",
      "description": "Estimated setup time.",
      "required": true,
      "example": "6 minutes"
    },
    {
      "name": "session_url",
      "type": "string",
      "description": "Absolute URL to guided setup.",
      "required": true,
      "example": "https://app.example.com/tour/brand-approvals",
      "format": "url"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Kai",
    "next_feature": "Brand approvals",
    "workspace_name": "Signal Market",
    "use_case_name": "Launch review",
    "time_estimate": "6 minutes",
    "session_url": "https://app.example.com/tour/brand-approvals"
  },
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Product Tour Follow-up</mj-title>\n    <mj-preview>A crisp lifecycle email that turns a guided tour into product adoption.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#1c1917\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#fff7ed\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#22120b\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#fb923c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Recommended next</mj-text>\n        <mj-text color=\"#fff7ed\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">Put {{next_feature}} to work today</mj-text>\n        <mj-text color=\"#fff7ed\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, based on the tour you completed, {{next_feature}} is the fastest next step for your {{workspace_name}} workflow.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#ffedd5\" color=\"#1c1917\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Recommended feature</mj-text>\n        <mj-text background-color=\"#ffedd5\" color=\"#1c1917\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{next_feature}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">Use case</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{use_case_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">Estimated setup</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{time_estimate}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#6b5d52;font-size:13px;\">Workspace</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fed7aa;color:#1c1917;font-size:13px;font-weight:700;\">{{workspace_name}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{session_url}}\" background-color=\"#fb923c\" color=\"#1c1007\" padding=\"26px 0 8px\">Open guided setup</mj-button>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">This recommendation is based on the product tour path selected in your workspace.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6b5d52\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "text": "Hi {{first_name}},\n\nbased on the tour you completed, {{next_feature}} is the fastest next step for your {{workspace_name}} workflow.\n\nRecommended feature: {{next_feature}}\nUse case: {{use_case_name}}\nEstimated setup: {{time_estimate}}\nWorkspace: {{workspace_name}}\n\nOpen guided setup: {{session_url}}\n\nThis recommendation is based on the product tour path selected in your workspace.",
