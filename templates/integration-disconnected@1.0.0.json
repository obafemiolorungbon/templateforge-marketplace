{
  "id": "integration-disconnected",
  "slug": "integration-disconnected",
  "name": "Integration Disconnected",
  "version": "1.0.0",
  "category": "notifications",
  "useCase": "Alert workspace owners when an integration needs reconnection.",
  "description": "A high-signal integration alert that gives teams the fastest recovery path.",
  "subject": "{{integration_name}} disconnected from {{workspace_name}}",
  "tags": [
    "transactional",
    "notifications",
    "integration",
    "alert"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Owen"
    },
    {
      "name": "integration_name",
      "type": "string",
      "description": "Integration name.",
      "required": true,
      "example": "Stripe"
    },
    {
      "name": "workspace_name",
      "type": "string",
      "description": "Workspace name.",
      "required": true,
      "example": "Atlas Ops"
    },
    {
      "name": "disconnected_at",
      "type": "string",
      "description": "Human-readable disconnect time.",
      "required": true,
      "example": "Today at 8:12 AM"
    },
    {
      "name": "affected_flow",
      "type": "string",
      "description": "Affected workflow name.",
      "required": true,
      "example": "Invoice sync"
    },
    {
      "name": "reconnect_url",
      "type": "url",
      "description": "Absolute URL to reconnect integration.",
      "required": true,
      "example": "https://app.example.com/integrations/stripe/reconnect"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Owen",
    "integration_name": "Stripe",
    "workspace_name": "Atlas Ops",
    "disconnected_at": "Today at 8:12 AM",
    "affected_flow": "Invoice sync",
    "reconnect_url": "https://app.example.com/integrations/stripe/reconnect"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\n{{integration_name}} disconnected from {{workspace_name}}. Reconnect it to keep automations and sync jobs running.\n\nIntegration: {{integration_name}}\nWorkspace: {{workspace_name}}\nDisconnected: {{disconnected_at}}\nAffected flow: {{affected_flow}}\n\nReconnect integration: {{reconnect_url}}\n\nWe paused affected sync jobs until the integration is connected again.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Integration Disconnected</mj-title>\n    <mj-preview>A high-signal integration alert that gives teams the fastest recovery path.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#1f1215\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#fff1f2\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#2a0d12\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#f43f5e\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Integration alert</mj-text>\n        <mj-text color=\"#fff7f8\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">{{integration_name}} needs attention</mj-text>\n        <mj-text color=\"#fff7f8\" font-size=\"15px\" line-height=\"24px\" padding=\"0\" opacity=\"0.84\">Hi {{first_name}}, {{integration_name}} disconnected from {{workspace_name}}. Reconnect it to keep automations and sync jobs running.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#ffe4e6\" color=\"#1f1215\" border-radius=\"18px\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Integration</mj-text>\n        <mj-text background-color=\"#ffe4e6\" color=\"#1f1215\" border-radius=\"18px\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{integration_name}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Workspace</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{workspace_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Disconnected</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{disconnected_at}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#6d555b;font-size:13px;\">Affected flow</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #fecdd3;color:#1f1215;font-size:13px;font-weight:700;\">{{affected_flow}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{reconnect_url}}\" background-color=\"#f43f5e\" color=\"#ffffff\" padding=\"26px 0 8px\">Reconnect integration</mj-button>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">We paused affected sync jobs until the integration is connected again.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#6d555b\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
