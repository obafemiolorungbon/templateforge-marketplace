{
  "id": "order-confirmation",
  "slug": "order-confirmation",
  "name": "Order Confirmation",
  "version": "1.0.0",
  "category": "commerce",
  "useCase": "Confirm a purchase with strong order summary hierarchy and a clear receipt link.",
  "description": "A premium commerce confirmation email for product, ticket, or digital purchases.",
  "subject": "Order {{order_number}} is confirmed",
  "tags": [
    "transactional",
    "commerce",
    "order",
    "receipt"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Noah"
    },
    {
      "name": "order_number",
      "type": "string",
      "description": "Order number.",
      "required": true,
      "example": "TF-10429"
    },
    {
      "name": "order_total",
      "type": "string",
      "description": "Order total.",
      "required": true,
      "example": "$128.00"
    },
    {
      "name": "delivery_estimate",
      "type": "string",
      "description": "Estimated delivery window.",
      "required": true,
      "example": "July 1 - July 3"
    },
    {
      "name": "payment_method",
      "type": "string",
      "description": "Payment method label.",
      "required": true,
      "example": "Visa ending in 4242"
    },
    {
      "name": "order_url",
      "type": "string",
      "description": "Absolute URL to order details.",
      "required": true,
      "example": "https://shop.example.com/orders/TF-10429"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Noah",
    "order_number": "TF-10429",
    "order_total": "$128.00",
    "delivery_estimate": "July 1 - July 3",
    "payment_method": "Visa ending in 4242",
    "order_url": "https://shop.example.com/orders/TF-10429"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\norder {{order_number}} is confirmed. We will send another update when it moves to fulfillment.\n\nOrder total: {{order_total}}\nOrder: {{order_number}}\nDelivery estimate: {{delivery_estimate}}\nPayment: {{payment_method}}\n\nView order: {{order_url}}\n\nYour receipt and order updates are available from the order page.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Order Confirmation</mj-title>\n    <mj-preview>A premium commerce confirmation email for product, ticket, or digital purchases.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#101114\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f3f4f0\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#050505\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#b8ff2c\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Order confirmed</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">We received your order</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\">Hi {{first_name}}, order {{order_number}} is confirmed. We will send another update when it moves to fulfillment.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Order total</mj-text>\n        <mj-text background-color=\"#efffd3\" color=\"#101114\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{order_total}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Order</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{order_number}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Delivery estimate</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{delivery_estimate}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#5f656f;font-size:13px;\">Payment</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #dde2d7;color:#101114;font-size:13px;font-weight:700;\">{{payment_method}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{order_url}}\" background-color=\"#b8ff2c\" color=\"#101114\" padding=\"26px 0 8px\">View order</mj-button>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">Your receipt and order updates are available from the order page.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#5f656f\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
