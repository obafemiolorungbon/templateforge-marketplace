{
  "id": "approval-request",
  "slug": "approval-request",
  "name": "Approval Request",
  "version": "1.0.0",
  "category": "notifications",
  "useCase": "Send approval requests with due dates, requester context, and a direct review action.",
  "description": "A polished workflow email for approvals, reviews, and internal controls.",
  "subject": "{{request_name}} needs your approval",
  "tags": [
    "transactional",
    "notifications",
    "approval",
    "workflow"
  ],
  "variables": [
    {
      "name": "product_name",
      "type": "string",
      "description": "Product or brand name displayed in the email header.",
      "required": true,
      "example": "TemplateForge"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Recipient first name.",
      "required": true,
      "example": "Mei"
    },
    {
      "name": "requester_name",
      "type": "string",
      "description": "Name of requester.",
      "required": true,
      "example": "Nadia Cole"
    },
    {
      "name": "request_name",
      "type": "string",
      "description": "Approval request name.",
      "required": true,
      "example": "Launch budget"
    },
    {
      "name": "due_date",
      "type": "string",
      "description": "Approval due date.",
      "required": true,
      "example": "June 28, 2026"
    },
    {
      "name": "workflow_name",
      "type": "string",
      "description": "Workflow name.",
      "required": true,
      "example": "Finance approval"
    },
    {
      "name": "priority_label",
      "type": "string",
      "description": "Priority label.",
      "required": true,
      "example": "High"
    },
    {
      "name": "approval_url",
      "type": "url",
      "description": "Absolute URL to approval request.",
      "required": true,
      "example": "https://app.example.com/approvals/launch-budget"
    }
  ],
  "sampleVariables": {
    "product_name": "TemplateForge",
    "first_name": "Mei",
    "requester_name": "Nadia Cole",
    "request_name": "Launch budget",
    "due_date": "June 28, 2026",
    "workflow_name": "Finance approval",
    "priority_label": "High",
    "approval_url": "https://app.example.com/approvals/launch-budget"
  },
  "qualityScore": {
    "visual_quality": 9,
    "copy_clarity": 9,
    "mobile_readiness": 9,
    "marketplace_usefulness": 9,
    "implementation_safety": 10,
    "originality": 9
  },
  "text": "Hi {{first_name}},\n\n{{requester_name}} sent {{request_name}} for approval. Review it before {{due_date}} to keep the workflow moving.\n\nDue: {{due_date}}\nRequested by: {{requester_name}}\nWorkflow: {{workflow_name}}\nPriority: {{priority_label}}\n\nReview request: {{approval_url}}\n\nIf you are not the right approver, reassign it from the review screen.",
  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Approval Request</mj-title>\n    <mj-preview>A polished workflow email for approvals, reviews, and internal controls.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif\" />\n      <mj-text color=\"#181229\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n      <mj-button border-radius=\"999px\" font-size=\"15px\" font-weight=\"800\" inner-padding=\"15px 24px\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f5f3ff\" width=\"600px\">\n    <mj-section padding=\"28px 22px 14px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#625a72\" font-size=\"12px\" font-weight=\"800\" letter-spacing=\"1.8px\" text-transform=\"uppercase\">{{product_name}}</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#1e123b\" border-radius=\"22px 22px 0 0\" padding=\"34px 34px 28px\">\n      <mj-column>\n        <mj-text color=\"#8b5cf6\" font-size=\"11px\" font-weight=\"900\" letter-spacing=\"2px\" text-transform=\"uppercase\" padding=\"0 0 14px\">Approval needed</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"30px\" font-weight=\"850\" line-height=\"36px\" padding=\"0 0 12px\">{{request_name}} is waiting on you</mj-text>\n        <mj-text color=\"#ffffff\" font-size=\"15px\" line-height=\"24px\" padding=\"0\" opacity=\"0.84\">Hi {{first_name}}, {{requester_name}} sent {{request_name}} for approval. Review it before {{due_date}} to keep the workflow moving.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"0 0 22px 22px\" padding=\"0 30px 30px\">\n      <mj-column>\n        <mj-spacer height=\"26px\" />\n        <mj-text background-color=\"#ede9fe\" color=\"#181229\" border-radius=\"18px\" font-size=\"13px\" font-weight=\"800\" line-height=\"20px\" padding=\"18px 20px 4px\">Due</mj-text>\n        <mj-text background-color=\"#ede9fe\" color=\"#181229\" border-radius=\"18px\" font-size=\"28px\" font-weight=\"900\" line-height=\"34px\" padding=\"0 20px 18px\">{{due_date}}</mj-text>\n        <mj-table padding=\"22px 0 4px\">\n          <tr><td style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#625a72;font-size:13px;\">Requested by</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#181229;font-size:13px;font-weight:700;\">{{requester_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#625a72;font-size:13px;\">Workflow</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#181229;font-size:13px;font-weight:700;\">{{workflow_name}}</td></tr><tr><td style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#625a72;font-size:13px;\">Priority</td><td align=\"right\" style=\"padding:12px 0;border-bottom:1px solid #ddd6fe;color:#181229;font-size:13px;font-weight:700;\">{{priority_label}}</td></tr>\n        </mj-table>\n        <mj-button href=\"{{approval_url}}\" background-color=\"#8b5cf6\" color=\"#ffffff\" padding=\"26px 0 8px\">Review request</mj-button>\n        <mj-text align=\"center\" color=\"#625a72\" font-size=\"13px\" line-height=\"20px\" padding=\"18px 10px 0\">If you are not the right approver, reassign it from the review screen.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"22px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#625a72\" font-size=\"12px\" line-height=\"18px\">TemplateForge marketplace template. Update branding and URLs before production use.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
  "author": "TemplateForge",
  "license": "MIT",
  "warnings": []
}
