  "mjml": "<mjml>\n  <mj-head>\n    <mj-title>Payment Failed</mj-title>\n    <mj-preview>A billing recovery email with one clear payment update action.</mj-preview>\n    <mj-attributes>\n      <mj-all font-family=\"-apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif\" />\n      <mj-text color=\"#172033\" font-size=\"16px\" line-height=\"24px\" />\n      <mj-section padding=\"0\" />\n    </mj-attributes>\n  </mj-head>\n  <mj-body background-color=\"#f5f7fb\" width=\"600px\">\n    <mj-section padding=\"32px 20px 18px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#667085\" font-size=\"13px\" font-weight=\"700\" letter-spacing=\"1.4px\" text-transform=\"uppercase\">TemplateForge</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section background-color=\"#ffffff\" border-radius=\"16px\" padding=\"0 0 12px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#101828\" font-size=\"26px\" font-weight=\"700\" line-height=\"32px\" padding=\"40px 32px 8px\">Payment Failed</mj-text>\n        <mj-text align=\"center\" color=\"#475467\" padding=\"0 36px 24px\">Hi {{first_name}}, Notify a customer that a payment failed and prompt them to update payment details.</mj-text>\n        <mj-text align=\"center\" background-color=\"#eef4ff\" color=\"#0f3f8f\" font-size=\"22px\" font-weight=\"800\" line-height=\"30px\" padding=\"20px 24px\">{{amount_due}}</mj-text>\n        <mj-text color=\"#475467\" font-size=\"14px\" line-height=\"20px\" padding=\"4px 32px\"><strong>Amount Due:</strong> {{amount_due}}</mj-text>\n        <mj-text color=\"#475467\" font-size=\"14px\" line-height=\"20px\" padding=\"4px 32px\"><strong>Plan Name:</strong> {{plan_name}}</mj-text>\n        <mj-button href=\"{{update_payment_url}}\" background-color=\"#155eef\" color=\"#ffffff\" border-radius=\"8px\" font-size=\"15px\" font-weight=\"700\" padding=\"28px 24px 10px\">View details</mj-button>\n        <mj-text align=\"center\" color=\"#667085\" font-size=\"14px\" line-height=\"22px\" padding=\"18px 36px 32px\">Need help? Visit {{support_url}}.</mj-text>\n      </mj-column>\n    </mj-section>\n    <mj-section padding=\"24px 20px 40px\">\n      <mj-column>\n        <mj-text align=\"center\" color=\"#8a94a6\" font-size=\"12px\" line-height=\"18px\">This is a transactional message.</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
